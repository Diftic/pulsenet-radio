<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="PulseNet Player"
    Version="$(var.ProductVersion)"
    Manufacturer="PulseNet Player"
    UpgradeCode="AFAACCA7-3810-4953-B21F-0122FF8106DE"
    Language="1033"
    Scope="perMachine">

    <Icon Id="AppIcon.ico" SourceFile="icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of PulseNet Player is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

    <Feature Id="Main" Title="PulseNet Player" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!-- Hotkey helper registration. The helper exe runs as a Scheduled Task
         that fires at user logon with Highest privileges in the user's
         interactive session. Cleared Windows 11 26200+ hook policy + bypasses
         EAC process-tree analysis + works around the Session 0 isolation
         that prevented a SYSTEM service from delivering hooks for user input.

         install-task.ps1 / uninstall-task.ps1 ship inside the install folder
         so the CAs can invoke them via [INSTALLFOLDER]. PowerShell.exe is
         referenced by absolute path because the SYSTEM PATH during MSI
         execution doesn't always include System32. -->
    <CustomAction Id="InstallHotkeyTask"
                  Directory="INSTALLFOLDER"
                  ExeCommand='"[%SystemRoot]\System32\WindowsPowerShell\v1.0\powershell.exe" -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "[INSTALLFOLDER]install-task.ps1" -BinPath "[INSTALLFOLDER]PulseNetHotkeyService.exe" -UserId "[LogonUser]"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="UninstallHotkeyTask"
                  Directory="INSTALLFOLDER"
                  ExeCommand='"[%SystemRoot]\System32\WindowsPowerShell\v1.0\powershell.exe" -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "[INSTALLFOLDER]uninstall-task.ps1"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Tear down the task before files are removed so uninstall-task.ps1
           can still see its own bits. Install the task after files land so
           install-task.ps1 can find the helper exe at the install path. -->
      <Custom Action="UninstallHotkeyTask" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="InstallHotkeyTask"   After="InstallFiles"
              Condition="NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>

  <Fragment>
    <!-- Per-machine MSI now installs to Program Files instead of LocalAppData
         so the helper exe is reachable from any user account on the machine
         (the scheduled task lives per-user, but the binary it points at is
         machine-wide). -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PulseNet Player" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="PulseNet Player" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="stage\**" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcut" Directory="AppMenuFolder">
      <Shortcut
        Id="ApplicationShortcut"
        Name="PulseNet Player"
        Description="Sci-fi YouTube music overlay for Star Citizen"
        Target="[INSTALLFOLDER]PulseNet-Player.exe"
        WorkingDirectory="INSTALLFOLDER"
        Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue
        Root="HKLM"
        Key="Software\PulseNet Player"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
